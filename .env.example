# Supabase project URL (https://<project-ref>.supabase.co). Required.
# Safe to ship to the client bundle.
VITE_SUPABASE_URL=

# Supabase anon (public) key. Required.
# Safe to ship: RLS policies enforce real authorization. Never use the
# service_role key here — see CLAUDE.md "Deployment" section.
VITE_SUPABASE_ANON_KEY=

# !!! DEV-ONLY !!!  DO NOT SET IN PRODUCTION (Cloudflare Pages env vars).
# Lets you preview locked/pending account screens without a real DB profile.
# Format: <role>:<status>  e.g. owner:activated | employee:locked | admin:pending
# Roles:    admin | owner | employee
# Statuses: activated | pending | locked
# Defense-in-depth:
#   1. CLAUDE.md forbids setting this in prod.
#   2. CI leak-grep in .github/workflows/deploy.yml fails the build if the
#      variable name appears in dist/.
#   3. src/shared/routing/useFakeProfile.ts throws at module-load time when
#      import.meta.env.PROD === true — last-ditch runtime backstop.
VITE_DEV_FAKE_PROFILE=
